<!-- ================================================================
     SERENNE — HEADER
     Minimal, premium, backdrop blur
     ================================================================ -->

<header class="serenne-header">
  <!-- ANNOUNCEMENT BAR -->
  <div class="announcement-bar">
    Envío gratuito en pedidos superiores a S/. 200
  </div>
  
  <div class="header-inner">
    <!-- LOGO -->
    <a href="/" class="header-logo">SERENNE</a>
    
    <!-- NAVIGATION -->
    <nav class="header-nav">
      <a href="/collections">Productos</a>
      <a href="/collections/rituales">Rituales</a>
      <a href="/pages/nuestra-historia">Filosofía</a>
      <a href="/pages/ingredientes">Ingredientes</a>
    </nav>
    
    <!-- ICONS -->
    <div class="header-icons">
      <button class="header-icon" aria-label="Buscar" onclick="openSearch()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <a href="/account" class="header-icon" aria-label="Mi cuenta">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>
      <button class="header-icon" aria-label="Carrito" onclick="openCart()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span id="cart-icon-count" style="position: absolute; top: -4px; right: -8px; background: var(--s-gold); color: white; font-size: 0.625rem; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; display: none;"></span>
      </button>
    </div>
  </div>
</header>

<script>
// Update cart icon count
function updateCartIconCount() {
  fetch('/cart.js')
    .then(res => res.json())
    .then(data => {
      const countEl = document.getElementById('cart-icon-count');
      if (data.item_count > 0) {
        countEl.textContent = data.item_count;
        countEl.style.display = 'flex';
      } else {
        countEl.style.display = 'none';
      }
    });
}

// Update on load
document.addEventListener('DOMContentLoaded', updateCartIconCount);

// Update after cart changes
const observer = new MutationObserver(() => {
  if (typeof cart !== 'undefined') {
    updateCartIconCount();
  }
});
</script>
