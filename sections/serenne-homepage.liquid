<style>
  @keyframes heroZoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  @keyframes heroFadeIn {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .hero { display: flex !important; min-height: 92vh; position: relative; align-items: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; animation: heroZoom 1.5s cubic-bezier(0.25, 0.1, 0.25, 1) forwards; }
  .hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(135deg, rgba(74,63,107,0.7) 0%, rgba(41,37,36,0.55) 40%, rgba(26,23,20,0.7) 100%); }
  .hero-overlay::after { content: ''; position: absolute; inset: 0; background: linear-gradient(0deg, rgba(26,23,20,0.3) 0%, transparent 50%, rgba(74,63,107,0.15) 100%); pointer-events: none; }
  .hero-content { background: transparent !important; position: relative; z-index: 2; padding: 120px 0 80px; }
  .hero-image-wrap { display: none !important; }
  .ritual-card-image { border-radius: 8px 8px 0 0; overflow: hidden; }
  .ritual-card-image img { width: 100%; height: 100%; object-fit: cover; }
  .ritual-product-mini { display: flex; align-items: center; gap: 8px; padding: 4px 0; }
  .ritual-product-mini-name { font-size: 0.75rem; }
  .ritual-product-mini-price { font-size: 0.75rem; color: var(--s-gold); margin-left: auto; }
</style>

<!-- 1. HERO -->
<section class="hero" data-section="hero">
  <div class="hero-bg">
    <img src="{{ "hero-bg.jpg" | asset_url }}" alt="Serenne bienestar premium" loading="eager" fetchpriority="high">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="label hero-label">SERENNE</div>
    <h1 class="hero-title reveal">Los mejores rituales comienzan cuando el mundo se detiene</h1>
    <p class="hero-subtitle reveal reveal-delay-1">Aceites naturales y rituales de bienestar que transforman tu día en ceremonia.</p>
    <div class="hero-ctas reveal reveal-delay-2">
      <a href="/collections" class="btn-primary" style="border-color: rgba(253,251,247,0.6); color: var(--s-ivory);">Comenzar mi ritual</a>
      <a href="/pages/nuestra-historia" class="btn-ghost" style="color: var(--s-ivory);">Conocer Serenne</a>
    </div>
  </div>
  <div class="hero-scroll">
    <span>Descubrir</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<!-- 2. FILOSOFÍA DE MARCA -->
