<section class="zym-page zym-container" style="padding-top: 120px; padding-bottom: 4rem;">
  <div class="zym-section-header">
    <h1 class="zym-title">Contacto</h1>
    <p class="zym-desc">Estamos aqui para ayudarte</p>
  </div>
  <div style="max-width: 600px; margin: 0 auto; text-align: center;">
    <div style="margin-bottom: 2rem;">
      <i class="fas fa-envelope" style="font-size: 2rem; color: var(--zym-primary); margin-bottom: 1rem;"></i>
      <h3 style="font-family: var(--zym-font-heading); margin-bottom: 0.5rem;">Email</h3>
      <p style="color: var(--zym-gray-600);">hola@zymera.com</p>
    </div>
    <div style="margin-bottom: 2rem;">
      <i class="fas fa-phone" style="font-size: 2rem; color: var(--zym-primary); margin-bottom: 1rem;"></i>
      <h3 style="font-family: var(--zym-font-heading); margin-bottom: 0.5rem;">Telefono</h3>
      <p style="color: var(--zym-gray-600);">+1 (555) 123-4567</p>
    </div>
    <div>
      <i class="fab fa-whatsapp" style="font-size: 2rem; color: var(--zym-primary); margin-bottom: 1rem;"></i>
      <h3 style="font-family: var(--zym-font-heading); margin-bottom: 0.5rem;">WhatsApp</h3>
      <p style="color: var(--zym-gray-600);">+1 (555) 123-4567</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Page",
  "settings": []
}
{% endschema %}
