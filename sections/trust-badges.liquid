<style>
.trust-badges-section {
  padding: 60px 0;
  background: var(--serenne-ivory);
  border-top: 1px solid var(--serenne-beige);
  border-bottom: 1px solid var(--serenne-beige);
}

.trust-badges-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
}

.trust-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16px;
}

.trust-badge-icon {
  width: 48px;
  height: 48px;
  color: var(--serenne-gold);
}

.trust-badge-icon svg {
  width: 100%;
  height: 100%;
}

.trust-badge-content h4 {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 500;
  color: var(--serenne-dark);
  margin-bottom: 4px;
}

.trust-badge-content p {
  font-size: 0.85rem;
  color: var(--serenne-mocha);
}

@media (max-width: 750px) {
  .trust-badges-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }
}

@media (max-width: 590px) {
  .trust-badges-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}
</style>
