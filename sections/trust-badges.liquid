<section class="zym-trust-section" style="background:#fff;padding:3rem 0;border-bottom:1px solid rgba(0,0,0,0.04);">
  <div class="zym-container">
    <div class="zym-trust-grid">
      {% for block in section.blocks %}
        <div class="zym-trust-card" {{ block.shopify_attributes }}>
          <div class="zym-trust-card__icon">
            <i class="fas {{ block.settings.icon }}"></i>
          </div>
          <div class="zym-trust-card__content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust Badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (Font Awesome class)", "default": "fa-truck" },
        { "type": "text", "id": "title", "label": "Title", "default": "Envio Gratis" },
        { "type": "text", "id": "description", "label": "Description", "default": "En pedidos mayores a $50" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        { "type": "trust", "settings": { "icon": "fa-truck", "title": "Envio Premium", "description": "Gratis en pedidos +$50" } },
        { "type": "trust", "settings": { "icon": "fa-shield-alt", "title": "Pago Seguro", "description": "Cifrado SSL 256-bit" } },
        { "type": "trust", "settings": { "icon": "fa-undo", "title": "Garantia 30 Dias", "description": "Devolucion completa" } },
        { "type": "trust", "settings": { "icon": "fa-leaf", "title": "100% Natural", "description": "Ingredientes premium" } }
      ]
    }
  ]
}
{% endschema %}
