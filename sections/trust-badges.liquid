{{ 'premium-custom.css' | asset_url | stylesheet_tag }}

<section class="trust-badges-section" id="trust-badges-{{ section.id }}">
  <div class="container">
    <div class="trust-badges-grid">
      {% if section.settings.badge_1_text != blank %}
        <div class="trust-badge">
          <div class="trust-badge-icon">
            {{ section.settings.badge_1_icon }}
          </div>
          <div class="trust-badge-content">
            <h4>{{ section.settings.badge_1_text }}</h4>
            {% if section.settings.badge_1_subtext != blank %}
              <p>{{ section.settings.badge_1_subtext }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if section.settings.badge_2_text != blank %}
        <div class="trust-badge">
          <div class="trust-badge-icon">
            {{ section.settings.badge_2_icon }}
          </div>
          <div class="trust-badge-content">
            <h4>{{ section.settings.badge_2_text }}</h4>
            {% if section.settings.badge_2_subtext != blank %}
              <p>{{ section.settings.badge_2_subtext }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if section.settings.badge_3_text != blank %}
        <div class="trust-badge">
          <div class="trust-badge-icon">
            {{ section.settings.badge_3_icon }}
          </div>
          <div class="trust-badge-content">
            <h4>{{ section.settings.badge_3_text }}</h4>
            {% if section.settings.badge_3_subtext != blank %}
              <p>{{ section.settings.badge_3_subtext }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if section.settings.badge_4_text != blank %}
        <div class="trust-badge">
          <div class="trust-badge-icon">
            {{ section.settings.badge_4_icon }}
          </div>
          <div class="trust-badge-content">
            <h4>{{ section.settings.badge_4_text }}</h4>
            {% if section.settings.badge_4_subtext != blank %}
              <p>{{ section.settings.badge_4_subtext }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

