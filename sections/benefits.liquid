<section class="zym-section zym-section--gray">
  <div class="zym-container">
    <div class="zym-benefits-grid">
      {% for block in section.blocks %}
        <div class="zym-benefit-card" {{ block.shopify_attributes }}>
          <div class="zym-benefit-icon">
            <i class="fas {{ block.settings.icon }}"></i>
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "settings": [],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "fa-leaf" },
        { "type": "text", "id": "title", "label": "Title", "default": "100% Natural" },
        { "type": "text", "id": "description", "label": "Description", "default": "Ingredientes naturales y organicos" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "fa-leaf", "title": "Ingredientes Puros", "description": "Cada ingrediente es seleccionado por su pureza y eficacia comprobada." } },
        { "type": "benefit", "settings": { "icon": "fa-truck", "title": "Envio Premium", "description": "Envio gratuito en pedidos mayores a $50. Empaque discreto y ecologico." } },
        { "type": "benefit", "settings": { "icon": "fa-award", "title": "Calidad Certificada", "description": "Libre de parabenos, sulfatos, siliconas y ingredientes sinteticos." } },
        { "type": "benefit", "settings": { "icon": "fa-heart", "title": "Garantia Total", "description": "Si no estas satisfecho, te devolvemos tu dinero. Sin preguntas." } }
      ]
    }
  ]
}
{% endschema %}
