<footer class="zym-footer">
  <div class="zym-container">
    <div class="zym-footer-grid">
      <div class="zym-footer-brand">
        <a href="/" class="zym-footer-logo">
          <span class="zym-footer-logo-text">{{ section.settings.logo_text }}</span>
        </a>
        {% if section.settings.tagline != blank %}
          <p class="zym-footer-tagline">{{ section.settings.tagline }}</p>
        {% endif %}
        <div class="zym-footer-social">
          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" class="zym-social-link" target="_blank">
              <i class="fab fa-instagram"></i>
            </a>
          {% endif %}
          {% if section.settings.facebook != blank %}
            <a href="{{ section.settings.facebook }}" class="zym-social-link" target="_blank">
              <i class="fab fa-facebook-f"></i>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="zym-footer-col">
        <h4 class="zym-footer-title">Tienda</h4>
        <ul class="zym-footer-list">
          {% for link in linklists[section.settings.menu_shop].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="zym-footer-col">
        <h4 class="zym-footer-title">Empresa</h4>
        <ul class="zym-footer-list">
          {% for link in linklists[section.settings.menu_company].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="zym-footer-col">
        <h4 class="zym-footer-title">Contacto</h4>
        <ul class="zym-footer-list zym-footer-contact">
          {% if section.settings.email != blank %}
            <li><i class="fas fa-envelope"></i> {{ section.settings.email }}</li>
          {% endif %}
          {% if section.settings.phone != blank %}
            <li><i class="fas fa-phone"></i> {{ section.settings.phone }}</li>
          {% endif %}
        </ul>
      </div>
    </div>

    <div class="zym-footer-bottom">
      <p class="zym-footer-copy">&copy; 2026 {{ section.settings.logo_text }}. Todos los derechos reservados.</p>
      <div class="zym-footer-payment">
        <i class="fab fa-cc-visa"></i>
        <i class="fab fa-cc-mastercard"></i>
        <i class="fab fa-cc-amex"></i>
        <i class="fab fa-cc-paypal"></i>
      </div>
    </div>
  </div>
</footer>

<style>
  .zym-footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .zym-footer-logo-text { font-family: var(--zym-font-heading); font-size: 1.5rem; font-weight: 700; color: var(--zym-white); }
  .zym-footer-tagline { color: var(--zym-gray-400); font-size: 0.9375rem; margin-top: 0.75rem; line-height: 1.6; }
  .zym-footer-social { display: flex; gap: 1rem; margin-top: 1.25rem; }
  .zym-social-link { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: var(--zym-gray-300); transition: 0.3s; }
  .zym-social-link:hover { background: var(--zym-primary); color: var(--zym-white); }
  .zym-footer-title { font-family: var(--zym-font-heading); font-size: 1rem; font-weight: 600; color: var(--zym-white); margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 1px; }
  .zym-footer-list li { margin-bottom: 0.75rem; }
  .zym-footer-list a { color: var(--zym-gray-400); font-size: 0.9375rem; transition: color 0.3s; }
  .zym-footer-list a:hover { color: var(--zym-primary-light); }
  .zym-footer-contact li { color: var(--zym-gray-400); font-size: 0.9375rem; display: flex; align-items: center; gap: 0.5rem; }
  .zym-footer-contact i { color: var(--zym-primary-light); width: 16px; }
  .zym-footer-bottom { display: flex; align-items: center; justify-content: space-between; padding-top: 1.5rem; }
  .zym-footer-copy { color: var(--zym-gray-500); font-size: 0.875rem; }
  .zym-footer-payment { display: flex; gap: 0.75rem; font-size: 1.5rem; color: var(--zym-gray-500); }
  @media (max-width: 768px) {
    .zym-footer-grid { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
    .zym-footer-social { justify-content: center; }
    .zym-footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "Zymera"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Tu bienestar comienza aqui."
    },
    {
      "type": "link_list",
      "id": "menu_shop",
      "label": "Shop Menu",
      "default": "footer-shop"
    },
    {
      "type": "link_list",
      "id": "menu_company",
      "label": "Company Menu",
      "default": "footer-company"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hola@zymera.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+1 (555) 123-4567"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook"
    }
  ]
}
{% endschema %}
