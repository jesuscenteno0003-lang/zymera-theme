<!-- ================================================================
     SERENNE — COLLECTION PAGE COMPLETA
     Editorial, no catálogo
     ================================================================ -->

{{ 'serenne-design-system.css' | asset_url | stylesheet_tag }}

<!-- COLLECTION HERO -->
<section class="collection-hero" style="min-height: 40vh;">
  <div class="collection-hero-bg">
    {% if collection.image != blank %}
      <img src="{{ collection.image | image_url: width: 1600 }}" 
           alt="{{ collection.title }}"
           loading="eager">
    {% else %}
      <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #4a3f6b 0%, #292524 100%);"></div>
    {% endif %}
  </div>
  <div class="collection-hero-overlay"></div>
  <div class="collection-hero-content">
    <div class="label mb-s reveal" style="color: var(--s-gold);">COLECCIÓN</div>
    <h1 class="collection-hero-title reveal reveal-delay-1">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p class="collection-hero-desc reveal reveal-delay-2">{{ collection.description }}</p>
    {% else %}
      <p class="collection-hero-desc reveal reveal-delay-2">Descubre nuestra selección de rituales para tu bienestar diario.</p>
    {% endif %}
  </div>
</section>

<!-- INTRODUCCIÓN EDITORIAL -->
<section class="section section--cream">
  <div class="container">
    <div class="max-w-md mx-auto text-center reveal">
      <div class="label mb-m" style="color: var(--s-gold);">{{ collection.title | upcase }}</div>
      <p class="body-lg">{{ collection.metafields.custom.introduction | default: "Cada producto en esta colección ha sido seleccionado con intención. No encontrará rellenos ni adornos — solo lo que su piel necesita para florecer." }}</p>
    </div>
  </div>
</section>

<!-- FILTROS -->
<section class="section" style="padding-top: 0; padding-bottom: var(--sp-2xl);">
  <div class="container">
    <div class="filters-bar">
      <div class="filters-pills">
        <a href="{{ collection.url }}" class="filter-pill active">Todos</a>
        {% for tag in collection.tags limit: 4 %}
          <span class="filter-pill" style="cursor: default; opacity: 0.6;">{{ tag }}</span>
        {% endfor %}
      </div>
      <div style="font-size: 0.75rem; color: var(--s-taupe);">
        {{ collection.products_count }} {{ collection.products_count | pluralize: 'producto', 'productos' }}
      </div>
    </div>
  </div>
</section>

<!-- PRODUCT GRID -->
<section class="section" style="padding-top: 0;">
  <div class="container">
    {% if collection.products.size > 0 %}
      <div class="grid grid-3">
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="product-card reveal" style="text-decoration: none;">
            <div class="product-card-image">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" 
                     alt="{{ product.title }}"
                     loading="lazy">
              {% else %}
                <div style="width: 100%; aspect-ratio: 1; background: linear-gradient(135deg, #F5F0EB 0%, #D6CFC7 100%); display: flex; align-items: center; justify-content: center;">
                  <span style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #4a3f6b; opacity: 0.3;">{{ product.title | slice: 0, 1 }}</span>
                </div>
              {% endif %}
            </div>
            <div class="product-card-category">{{ product.type | default: "RITUAL" }}</div>
            <div class="product-card-name">{{ product.title }}</div>
            <div class="product-card-price">
              {{ product.price | money }}
              {% if product.compare_at_price > product.price %}
                <span style="text-decoration: line-through; color: var(--s-taupe); margin-left: 8px; font-size: 0.8125rem;">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="text-center" style="padding: var(--sp-4xl) 0;">
        <div class="h1 mb-l">Próximamente</div>
        <p class="body-lg" style="max-width: 480px; margin: 0 auto;">Estamos preparando rituales especiales para ti. Vuelve pronto para descubrir nuestra colección.</p>
      </div>
    {% endif %}

    <!-- PAGINACIÓN -->
    {% if paginate.pages > 1 %}
      <div style="padding: var(--sp-2xl) 0; text-align: center;">
        <div style="display: inline-flex; gap: 8px;">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="filter-pill">← Anterior</a>
          {% endif %}
          
          {% for page in paginate.pages %}
            {% if page == paginate.current_page %}
              <span class="filter-pill active">{{ page }}</span>
            {% else %}
              <a href="{{ paginate.pages[page_index].url }}" class="filter-pill">{{ page }}</a>
            {% endif %}
          {% endfor %}
          
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="filter-pill">Siguiente →</a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<!-- NEWSLETTER -->
<section class="section section--dark" data-section="newsletter">
  <div class="container text-center">
    <div class="label mb-l" style="color: var(--s-gold);">CÍRCULO SERENNE</div>
    <h2 class="h1 mb-l reveal" style="color: var(--s-ivory);">Recibe inspiración para tus rituales</h2>
    <p class="body-lg mb-2xl reveal reveal-delay-1" style="color: rgba(253,251,247,0.7); max-width: 480px; margin-left: auto; margin-right: auto;">Rituales, ingredientes y promociones exclusivas directamente en tu correo.</p>
    
    <form class="newsletter-form reveal reveal-delay-2" action="/contact#newsletter" method="post">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="tags" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Tu correo electrónico" required>
      <button type="submit">Unirme</button>
    </form>
    <p class="caption mt-s reveal reveal-delay-3" style="color: rgba(253,251,247,0.4);">Respetamos tu privacidad. Sin spam, solo inspiración.</p>
  </div>
</section>

{% schema %}
{
  "name": "Serenne Collection",
  "settings": [],
  "blocks": []
}
{% endschema %}
