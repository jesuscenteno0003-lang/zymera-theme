<section class="zym-section" style="background:#FAF9F7;">
  <div class="zym-container">
    <div class="zym-section-header">
      {% if section.settings.subtitle != blank %}
        <span class="zym-section-subtitle">{{ section.settings.subtitle }}</span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="zym-section-title">{{ section.settings.title }}</h2>
      {% endif %}
    </div>
    <div class="zym-testimonials-grid">
      {% for block in section.blocks %}
        <div class="zym-testimonial-card" {{ block.shopify_attributes }}>
          <div class="zym-testimonial-badge">
            <i class="fas fa-check-circle"></i> Compra Verificada
          </div>
          <div class="zym-testimonial-stars">
            {% assign rating = block.settings.rating | default: 5 %}
            {% for i in (1..5) %}
              {% if i <= rating %}
                <i class="fas fa-star"></i>
              {% else %}
                <i class="far fa-star" style="opacity:0.3;"></i>
              {% endif %}
            {% endfor %}
          </div>
          <p class="zym-testimonial-text">{{ block.settings.text }}</p>
          <div class="zym-testimonial-author">
            <div class="zym-testimonial-avatar">{{ block.settings.initials }}</div>
            <div>
              <span class="zym-testimonial-name">{{ block.settings.name }}</span>
              <span class="zym-testimonial-location">{{ block.settings.location }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Testimonios" },
    { "type": "text", "id": "title", "label": "Title", "default": "Lo que Dicen Nuestros Clientes" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Text" },
        { "type": "text", "id": "initials", "label": "Initials" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "location", "label": "Location" },
        { "type": "range", "id": "rating", "label": "Star Rating", "min": 1, "max": 5, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "text": "El aceite esencial de lavanda transformo mis noches. Duermo profundo y despierto renovada. No es solo un producto, es un ritual que atesoro.",
            "initials": "MG",
            "name": "Maria Garcia",
            "location": "Ciudad de Mexico",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "text": "El serum de vitamina C dejo mi piel con un brillo natural que nunca logre con productos comerciales. La calidad se nota desde la primera aplicacion.",
            "initials": "LR",
            "name": "Laura Rodriguez",
            "location": "Bogota, Colombia",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "text": "Como instructora de yoga, necesito productos que reflejen los mismos valores de calidad y consciencia. Zymera es exactamente eso.",
            "initials": "CM",
            "name": "Camila Mendoza",
            "location": "Lima, Peru",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
