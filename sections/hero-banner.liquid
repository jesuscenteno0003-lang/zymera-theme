<section class="zym-hero">
  <div class="zym-hero-grid zym-container">
    <div class="zym-hero-content">
      {% if section.settings.subtitle != blank %}
        <span class="zym-hero-subtitle">{{ section.settings.subtitle }}</span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h1 class="zym-hero-title">{{ section.settings.title }}</h1>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="zym-hero-desc">{{ section.settings.description }}</p>
      {% endif %}
      <div class="zym-hero-buttons">
        {% if section.settings.btn_primary_text != blank %}
          <a href="{{ section.settings.btn_primary_link }}" class="zym-btn zym-btn--primary">{{ section.settings.btn_primary_text }}</a>
        {% endif %}
        {% if section.settings.btn_secondary_text != blank %}
          <a href="{{ section.settings.btn_secondary_link }}" class="zym-btn zym-btn--secondary">{{ section.settings.btn_secondary_text }}</a>
        {% endif %}
      </div>
      <div class="zym-hero-features">
        {% if section.settings.feature_1 != blank %}
          <div class="zym-hero-feature"><i class="fas fa-leaf"></i><span>{{ section.settings.feature_1 }}</span></div>
        {% endif %}
        {% if section.settings.feature_2 != blank %}
          <div class="zym-hero-feature"><i class="fas fa-truck"></i><span>{{ section.settings.feature_2 }}</span></div>
        {% endif %}
        {% if section.settings.feature_3 != blank %}
          <div class="zym-hero-feature"><i class="fas fa-certificate"></i><span>{{ section.settings.feature_3 }}</span></div>
        {% endif %}
      </div>
    </div>
    <div class="zym-hero-image">
      <div class="zym-hero-image-container">
        <div class="zym-hero-image-circle"></div>
        <div class="zym-hero-image-main">
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | img_url: '600x600' }}" alt="{{ section.settings.image.alt | default: 'Zymera' }}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
          {% else %}
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="200" cy="200" r="180" fill="url(#zymgrad)"/>
              <path d="M200 80C200 80 120 160 120 220C120 264.183 155.817 300 200 300C244.183 300 280 264.183 280 220C280 160 200 80 200 80Z" fill="white" fill-opacity="0.3"/>
              <path d="M200 120C200 120 150 180 150 220C150 247.614 172.386 270 200 270C227.614 270 250 247.614 250 220C250 180 200 120 200 120Z" fill="white" fill-opacity="0.5"/>
              <defs>
                <linearGradient id="zymgrad" x1="200" y1="20" x2="200" y2="380" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#4A7C59"/>
                  <stop offset="1" stop-color="#2D5A3D"/>
                </linearGradient>
              </defs>
            </svg>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Bienvenido a tu Buena Vida"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Nutre tu cuerpo, alimenta tu alma"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Descubre productos naturales para elevar tu bienestar diario."
    },
    {
      "type": "text",
      "id": "btn_primary_text",
      "label": "Primary Button Text",
      "default": "Explorar Tienda"
    },
    {
      "type": "url",
      "id": "btn_primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn_secondary_text",
      "label": "Secondary Button Text",
      "default": "Nuestra Historia"
    },
    {
      "type": "url",
      "id": "btn_secondary_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "100% Natural"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Envio Gratis"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Premium Quality"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
