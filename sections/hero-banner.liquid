<section class="zym-hero" style="position:relative;min-height:85vh;display:flex;align-items:center;padding-top:72px;overflow:hidden;">
  <div style="position:absolute;inset:0;z-index:0;">
    <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1920&q=80" alt="Meditation" style="width:100%;height:100%;object-fit:cover;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(45,90,61,0.85) 0%,rgba(74,124,89,0.7) 50%,rgba(0,0,0,0.3) 100%);"></div>
  </div>
  <div style="position:relative;z-index:1;width:100%;max-width:1200px;margin:0 auto;padding:0 1.5rem;">
    <div style="max-width:620px;color:#fff;">
      <span style="display:inline-block;font-family:'Montserrat',sans-serif;font-size:0.75rem;font-weight:700;color:#D4AF37;text-transform:uppercase;letter-spacing:4px;margin-bottom:1.25rem;background:rgba(212,175,55,0.15);padding:0.5rem 1.25rem;border-radius:50px;border:1px solid rgba(212,175,55,0.3);">Bienvenido a tu Buena Vida</span>
      <h1 style="font-family:'Montserrat',sans-serif;font-size:clamp(2.25rem,5vw,3.75rem);font-weight:700;color:#fff;line-height:1.1;margin-bottom:1.5rem;">Nutre tu cuerpo, alimenta tu alma</h1>
      <p style="font-size:1.125rem;color:rgba(255,255,255,0.9);max-width:520px;margin-bottom:2.5rem;line-height:1.7;">Descubre productos naturales disenados para elevar tu bienestar diario.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3rem;">
        <a href="/collections/all" style="display:inline-flex;align-items:center;justify-content:center;padding:0.875rem 2rem;font-family:'Montserrat',sans-serif;font-size:0.8125rem;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;border-radius:8px;background:linear-gradient(135deg,#4A7C59 0%,#2D5A3D 100%);color:#fff;box-shadow:0 4px 15px rgba(74,124,89,0.3);text-decoration:none;">Comprar Ahora</a>
        <a href="/pages/about" style="display:inline-flex;align-items:center;justify-content:center;padding:0.875rem 2rem;font-family:'Montserrat',sans-serif;font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;border-radius:8px;background:#fff;color:#4A7C59;text-decoration:none;">Nuestra Historia</a>
      </div>
      <div style="display:flex;gap:2rem;border-top:1px solid rgba(255,255,255,0.2);padding-top:2rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:rgba(255,255,255,0.85);font-weight:500;"><i class="fas fa-shield-alt" style="color:#D4AF37;"></i> Pago Seguro</div>
        <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:rgba(255,255,255,0.85);font-weight:500;"><i class="fas fa-truck" style="color:#D4AF37;"></i> Envio Gratis +$50</div>
        <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:rgba(255,255,255,0.85);font-weight:500;"><i class="fas fa-undo" style="color:#D4AF37;"></i> Devolucion 30 dias</div>
      </div>
    </div>
  </div>
</section>

