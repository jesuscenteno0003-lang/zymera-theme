<section class="zym-hero">
  <div class="zym-hero-bg">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 1920 }}" alt="" class="zym-hero-bg-img">
    {% else %}
      <img src="https://images.unsplash.com/photo-1545205597-3d9d02c29597?w=1920&q=80" alt="" class="zym-hero-bg-img">
    {% endif %}
    <div class="zym-hero-overlay"></div>
  </div>
  <div class="zym-hero-grid zym-container">
    <div class="zym-hero-content">
      {% if section.settings.subtitle != blank %}
        <span class="zym-hero-subtitle">{{ section.settings.subtitle }}</span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h1 class="zym-hero-title">{{ section.settings.title }}</h1>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="zym-hero-desc">{{ section.settings.description }}</p>
      {% endif %}
      <div class="zym-hero-buttons">
        {% if section.settings.btn_primary_text != blank %}
          <a href="{{ section.settings.btn_primary_link }}" class="zym-btn zym-btn--primary">{{ section.settings.btn_primary_text }}</a>
        {% endif %}
        {% if section.settings.btn_secondary_text != blank %}
          <a href="{{ section.settings.btn_secondary_link }}" class="zym-btn zym-btn--white">{{ section.settings.btn_secondary_text }}</a>
        {% endif %}
      </div>
      <div class="zym-hero-trust">
        <div class="zym-hero-trust-item">
          <i class="fas fa-shield-alt"></i>
          <span>Pago Seguro</span>
        </div>
        <div class="zym-hero-trust-item">
          <i class="fas fa-truck"></i>
          <span>Envio Gratis +$50</span>
        </div>
        <div class="zym-hero-trust-item">
          <i class="fas fa-undo"></i>
          <span>Devolucion 30 dias</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Bienvenido a tu Buena Vida"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Nutre tu cuerpo, alimenta tu alma"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Descubre productos naturales disenados para elevar tu bienestar diario."
    },
    {
      "type": "text",
      "id": "btn_primary_text",
      "label": "Primary Button Text",
      "default": "Comprar Ahora"
    },
    {
      "type": "url",
      "id": "btn_primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn_secondary_text",
      "label": "Secondary Button Text",
      "default": "Nuestra Historia"
    },
    {
      "type": "url",
      "id": "btn_secondary_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Background Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
