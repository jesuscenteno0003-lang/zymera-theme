<section class="zym-product-page zym-container">
  <nav class="zym-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <span>/</span>
    <a href="/collections/all">Tienda</a>
    <span>/</span>
    <span>{{ product.title }}</span>
  </nav>

  <div class="zym-pdp">
    <div class="zym-pdp-gallery">
      <div class="zym-pdp-main-image">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" id="zym-pdp-img">
        {% else %}
          <div class="zym-product-card__placeholder" style="height:500px"><i class="fas fa-image" style="font-size:3rem"></i></div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="zym-pdp-thumbs">
          {% for image in product.images limit: 4 %}
            <img src="{{ image | image_url: width: 100 }}" alt="{{ image.alt }}" class="zym-pdp-thumb {% if forloop.first %}active{% endif %}" onclick="document.getElementById('zym-pdp-img').src='{{ image | image_url: width: 800 }}'">
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="zym-pdp-info">
      {% if product.vendor != blank %}
        <span class="zym-pdp-vendor">{{ product.vendor }}</span>
      {% endif %}
      <h1 class="zym-pdp-title">{{ product.title }}</h1>
      <div class="zym-pdp-rating">
        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
        <span>(4.5) - {{ product.all_reviews_count | default: 23 }} reviews</span>
      </div>
      <div class="zym-pdp-price">
        <span class="zym-pdp-price__current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="zym-pdp-price__compare">{{ product.compare_at_price | money }}</span>
          <span class="zym-pdp-price__discount">-{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}%</span>
        {% endif %}
      </div>

      <div class="zym-pdp-short-desc">
        {% if product.description != blank %}
          <p>{{ product.description | strip_html | truncatewords: 30 }}</p>
        {% endif %}
      </div>

      <div class="zym-pdp-stock">
        <i class="fas fa-check-circle"></i>
        <span>En stock - listo para enviar</span>
      </div>

      <form method="post" action="/cart/add" class="zym-pdp-form">
        {% if product.variants.size > 1 %}
          <div class="zym-pdp-variants">
            <label>Opciones:</label>
            <select name="id" class="zym-pdp-select">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if forloop.first %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }} {% unless variant.available %}(Agotado){% endunless %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {% endif %}
        <button type="submit" class="zym-btn zym-btn--primary zym-pdp-add">
          <i class="fas fa-shopping-cart"></i> Agregar al Carrito
        </button>
      </form>

      <div class="zym-pdp-guarantees">
        <div class="zym-pdp-guarantee"><i class="fas fa-truck"></i> Envio gratis en pedidos +$50</div>
        <div class="zym-pdp-guarantee"><i class="fas fa-undo"></i> Garantia de devolucion 30 dias</div>
        <div class="zym-pdp-guarantee"><i class="fas fa-shield-alt"></i> Pago 100% seguro</div>
        <div class="zym-pdp-guarantee"><i class="fas fa-headset"></i> Soporte al cliente 24/7</div>
      </div>
    </div>
  </div>

  {% if product.description != blank %}
    <div class="zym-pdp-description">
      <h2>Descripcion del Producto</h2>
      <div class="zym-pdp-description-content">{{ product.description }}</div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
