<section style="padding:5rem 0;">
  <div style="width:100%;max-width:1200px;margin:0 auto;padding:0 1.5rem;">
    <div style="margin-bottom:3rem;">
      <span style="display:block;font-family:'Montserrat',sans-serif;font-size:0.75rem;font-weight:700;color:#4A7C59;text-transform:uppercase;letter-spacing:3px;margin-bottom:0.75rem;text-align:center;">Explora</span>
      <h2 style="font-family:'Montserrat',sans-serif;font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;color:#212121;text-align:center;margin-bottom:1rem;line-height:1.2;">Nuestras Categorias</h2>
      <p style="text-align:center;color:#757575;font-size:1.0625rem;max-width:560px;margin:0 auto;">Encuentra lo que tu cuerpo y alma necesitan</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;">
      <a href="/collections/aromaterapia" style="position:relative;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:2.5rem 1.5rem;min-height:320px;border-radius:16px;text-align:center;overflow:hidden;text-decoration:none;color:#fff;">
        <img src="https://images.unsplash.com/photo-1602928321679-560bb453f190?w=600&q=80" alt="Aromaterapia" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.65) 100%);"></div>
        <div style="position:relative;z-index:2;"><i class="fas fa-spa" style="font-size:1.5rem;"></i></div>
        <h3 style="position:relative;z-index:2;font-family:'Montserrat',sans-serif;font-size:1.125rem;font-weight:700;margin-top:0.5rem;">Aromaterapia</h3>
        <span style="position:relative;z-index:2;color:rgba(255,255,255,0.8);font-size:0.8125rem;">12 productos</span>
      </a>
      <a href="/collections/skincare" style="position:relative;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:2.5rem 1.5rem;min-height:320px;border-radius:16px;text-align:center;overflow:hidden;text-decoration:none;color:#fff;">
        <img src="https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=600&q=80" alt="Skincare" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.65) 100%);"></div>
        <div style="position:relative;z-index:2;"><i class="fas fa-pump-soap" style="font-size:1.5rem;"></i></div>
        <h3 style="position:relative;z-index:2;font-family:'Montserrat',sans-serif;font-size:1.125rem;font-weight:700;margin-top:0.5rem;">Skincare</h3>
        <span style="position:relative;z-index:2;color:rgba(255,255,255,0.8);font-size:0.8125rem;">15 productos</span>
      </a>
      <a href="/collections/yoga-meditacion" style="position:relative;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:2.5rem 1.5rem;min-height:320px;border-radius:16px;text-align:center;overflow:hidden;text-decoration:none;color:#fff;">
        <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600&q=80" alt="Yoga" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.65) 100%);"></div>
        <div style="position:relative;z-index:2;"><i class="fas fa-om" style="font-size:1.5rem;"></i></div>
        <h3 style="position:relative;z-index:2;font-family:'Montserrat',sans-serif;font-size:1.125rem;font-weight:700;margin-top:0.5rem;">Yoga & Meditacion</h3>
        <span style="position:relative;z-index:2;color:rgba(255,255,255,0.8);font-size:0.8125rem;">8 productos</span>
      </a>
      <a href="/collections/sueno-descanso" style="position:relative;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:2.5rem 1.5rem;min-height:320px;border-radius:16px;text-align:center;overflow:hidden;text-decoration:none;color:#fff;">
        <img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=600&q=80" alt="Sueno" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.65) 100%);"></div>
        <div style="position:relative;z-index:2;"><i class="fas fa-moon" style="font-size:1.5rem;"></i></div>
        <h3 style="position:relative;z-index:2;font-family:'Montserrat',sans-serif;font-size:1.125rem;font-weight:700;margin-top:0.5rem;">Sueno & Descanso</h3>
        <span style="position:relative;z-index:2;color:rgba(255,255,255,0.8);font-size:0.8125rem;">10 productos</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "settings": [],
  "presets": [ { "name": "Featured Categories" } ]
}
{% endschema %}