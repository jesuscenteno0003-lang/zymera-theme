<section class="zym-section">
  <div class="zym-container">
    <div class="zym-section-header">
      <span class="zym-subtitle">Explora</span>
      <h2 class="zym-title">Nuestras Categorias</h2>
      <p class="zym-desc">Encuentra lo que tu cuerpo y alma necesitan</p>
    </div>
    <div class="zym-categories-grid">
      <a href="/collections/aromaterapia" class="zym-category-card">
        <div class="zym-category-bg">
          <img src="https://images.unsplash.com/photo-1602928321679-560bb453f190?w=600&q=80" alt="Aromaterapia" loading="lazy">
        </div>
        <div class="zym-category-overlay"></div>
        <div class="zym-category-icon"><i class="fas fa-spa"></i></div>
        <h3>Aromaterapia</h3>
        <span class="zym-category-count">12 productos</span>
      </a>
      <a href="/collections/skincare" class="zym-category-card">
        <div class="zym-category-bg">
          <img src="https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=600&q=80" alt="Skincare" loading="lazy">
        </div>
        <div class="zym-category-overlay"></div>
        <div class="zym-category-icon"><i class="fas fa-pump-soap"></i></div>
        <h3>Skincare</h3>
        <span class="zym-category-count">15 productos</span>
      </a>
      <a href="/collections/yoga-meditacion" class="zym-category-card">
        <div class="zym-category-bg">
          <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600&q=80" alt="Yoga" loading="lazy">
        </div>
        <div class="zym-category-overlay"></div>
        <div class="zym-category-icon"><i class="fas fa-om"></i></div>
        <h3>Yoga & Meditacion</h3>
        <span class="zym-category-count">8 productos</span>
      </a>
      <a href="/collections/sueno-descanso" class="zym-category-card">
        <div class="zym-category-bg">
          <img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=600&q=80" alt="Sueno" loading="lazy">
        </div>
        <div class="zym-category-overlay"></div>
        <div class="zym-category-icon"><i class="fas fa-moon"></i></div>
        <h3>Sueno & Descanso</h3>
        <span class="zym-category-count">10 productos</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Explora" },
    { "type": "text", "id": "title", "label": "Title", "default": "Nuestras Categorias" },
    { "type": "text", "id": "description", "label": "Description", "default": "Encuentra lo que tu cuerpo y alma necesitan" }
  ],
  "presets": [ { "name": "Featured Categories" } ]
}
{% endschema %}
