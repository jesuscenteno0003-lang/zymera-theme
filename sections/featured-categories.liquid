<section class="zym-section">
  <div class="zym-container">
    <div class="zym-section-header">
      {% if section.settings.subtitle != blank %}
        <span class="zym-subtitle">{{ section.settings.subtitle }}</span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="zym-title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="zym-desc">{{ section.settings.description }}</p>
      {% endif %}
    </div>
    <div class="zym-categories-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="zym-category-card" {{ block.shopify_attributes }} style="{% if block.settings.image != blank %}background-image: url('{{ block.settings.image | image_url: width: 600 }}'); background-size: cover; background-position: center;{% endif %}">
          <div class="zym-category-overlay"></div>
          <div class="zym-category-icon">
            <i class="fas {{ block.settings.icon | default: 'fa-leaf' }}"></i>
          </div>
          <h3>{{ block.settings.title }}</h3>
          {% if block.settings.count != blank %}
            <span class="zym-category-count">{{ block.settings.count }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Explora"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Nuestras Categorias"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Encuentra lo que tu cuerpo y alma necesitan"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Aromaterapia"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Count",
          "default": "12 productos"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Font Awesome class)",
          "default": "fa-leaf"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Aromaterapia",
            "count": "12 productos",
            "icon": "fa-spa"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Skincare",
            "count": "15 productos",
            "icon": "fa-pump-soap"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Yoga y Meditacion",
            "count": "8 productos",
            "icon": "fa-om"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Sueno y Descanso",
            "count": "10 productos",
            "icon": "fa-moon"
          }
        }
      ]
    }
  ]
}
{% endschema %}
