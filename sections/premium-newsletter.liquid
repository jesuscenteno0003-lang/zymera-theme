<section class="newsletter section" id="newsletter-{{ section.id }}">
  <div class="container">
    {%- comment -%} Force Spanish text {%- endcomment -%}
    {% assign section_label = 'Newsletter' %}
    {% assign section_title = 'Únete a nuestro círculo' %}
    {% assign section_text = 'Recibe acceso anticipado a nuevos lanzamientos, rituales de cuidado personal y un 10% de descuento en tu primera compra.' %}
    {% assign placeholder = 'Tu correo electrónico' %}
    {% assign button_text = 'Suscribirse' %}
    {% assign privacy_text = 'Respetamos tu privacidad. Puedes darte de baja en cualquier momento.' %}
    <div class="newsletter-inner reveal">
      <span class="section-label" style="color: var(--serenne-gold-light);">{{ section_label }}</span>
      <h2 class="newsletter-title">{{ section_title }}</h2>
      <p class="newsletter-text">{{ section_text }}</p>
      
      <form class="newsletter-form" action="/contact#newsletter" method="post">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input 
          type="email" 
          name="contact[email]" 
          class="newsletter-input" 
          placeholder="{{ placeholder }}"
          required
          aria-label="Correo electrónico"
        >
        <button type="submit" class="newsletter-btn">{{ button_text }}</button>
      </form>
      
      <p class="newsletter-privacy">{{ privacy_text }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Premium",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Únete a nuestro círculo"
    },
    {
      "type": "textarea",
      "id": "section_text",
      "label": "Section Text",
      "default": "Recibe acceso anticipado a nuevos lanzamientos, rituales de cuidado personal y un 10% de descuento en tu primera compra."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Tu correo electrónico"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Suscribirse"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy Text",
      "default": "Respetamos tu privacidad. Puedes darte de baja en cualquier momento."
    }
  ],
  "presets": [
    {
      "name": "Newsletter Premium"
    }
  ]
}
{% endschema %}
