<!-- ================================================================
     SERENNE — PRODUCT PAGE COMPLETA
     Transformación narrative — vende transformación, no características
     ================================================================ -->

{{ 'serenne-design-system.css' | asset_url | stylesheet_tag }}

<div class="section" style="padding-top: 120px;">
  <div class="container">
    <!-- BREADCRUMB -->
    <nav class="breadcrumb mb-l reveal" style="font-size: 0.75rem; color: var(--s-taupe);">
      <a href="/" style="color: var(--s-taupe); transition: color 0.3s ease;">Inicio</a>
      <span style="margin: 0 8px;">›</span>
      <a href="/collections/aromaterapia" style="color: var(--s-taupe); transition: color 0.3s ease;">Aromaterapia</a>
      <span style="margin: 0 8px;">›</span>
      <span style="color: var(--s-dark);">{{ product.title }}</span>
    </nav>

    <div class="product-layout">
      <!-- MEDIA GALLERY -->
      <div class="product-media reveal">
        <div class="product-main-image">
          {% if product.featured_image != blank %}
            <img src="{{ product.featured_image | image_url: width: 800 }}" 
                 alt="{{ product.title }}"
                 loading="eager">
          {% else %}
            <div style="width: 100%; aspect-ratio: 1; background: linear-gradient(135deg, #F5F0EB 0%, #D6CFC7 100%); display: flex; align-items: center; justify-content: center;">
              <span style="font-family: 'Playfair Display', serif; font-size: 4rem; color: #4a3f6b; opacity: 0.2;">{{ product.title | slice: 0, 1 }}</span>
            </div>
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-thumbnails">
            {% for image in product.images limit: 4 %}
              <div class="product-thumbnail {% if forloop.first %}active{% endif %}">
                <img src="{{ image | image_url: width: 150 }}" 
                     alt="{{ product.title }}"
                     loading="lazy">
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- PRODUCT INFO -->
      <div class="product-info">
        <div class="label mb-s reveal">{{ product.type | default: "RITUAL" }}</div>
        
        <h1 class="product-title reveal reveal-delay-1">{{ product.title }}</h1>
        
        {% if product.metafields.descriptors.subtitle %}
          <p class="product-subtitle reveal reveal-delay-1">{{ product.metafields.descriptors.subtitle }}</p>
        {% endif %}

        <hr class="divider divider--thin">

        <div class="product-price reveal reveal-delay-2">
          {{ product.price | money }}
          {% if product.compare_at_price > product.price %}
            <span style="text-decoration: line-through; color: var(--s-taupe); margin-left: 8px; font-size: 0.875rem;">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </div>

        <hr class="divider divider--thin">

        <!-- DESCRIPCIÓN NARRATIVA -->
        <div class="product-description reveal reveal-delay-2">
          {{ product.description }}
        </div>

        <!-- BENEFICIOS -->
        <div class="product-benefits reveal reveal-delay-3">
          <div class="product-benefit">🌿 100% Natural</div>
          <div class="product-benefit">🧴 Puro</div>
          <div class="product-benefit">✨ Efectivo</div>
        </div>

        <!-- VARIANTES -->
        {% unless product.has_only_default_variant %}
          {% for option in product.options %}
            <div class="variant-label">{{ option.name }}</div>
            <div class="variant-options mb-l">
              {% for value in option.values %}
                <button class="variant-option {% if forloop.first %}active{% endif %}"
                        data-option="{{ option.name }}"
                        data-value="{{ value }}">
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          {% endfor %}
        {% endunless %}

        <!-- CANTIDAD -->
        <div class="variant-label">Cantidad</div>
        <div class="quantity-selector mb-l">
          <button class="quantity-btn" data-action="decrease">−</button>
          <div class="quantity-value" id="quantity">1</div>
          <button class="quantity-btn" data-action="increase">+</button>
        </div>

        <!-- CTA -->
        <div class="product-cta reveal">
          <button class="btn-gold" style="width: 100%;" id="add-to-cart">
            Añadir al carrito
          </button>
        </div>

        <!-- SHIPPING NOTE -->
        <div class="shipping-note reveal">
          <span>🔒</span>
          <span>Envío gratuito en pedidos superiores a S/. 200</span>
        </div>

        <hr class="divider divider--thin">

        <!-- CÓMO USAR -->
        <div class="reveal" style="margin-bottom: var(--sp-xl);">
          <div class="label mb-m">CÓMO USAR TU RITUAL</div>
          <div class="body" style="line-height: 2;">
            <p><strong style="color: var(--s-dark);">1. Respira.</strong> Abre el frasco y toma tres respiraciones profundas. Deja que el aroma llene tus sentidos.</p>
            <p style="margin-top: 8px;"><strong style="color: var(--s-dark);">2. Aplica.</strong> Coloca 2-3 gotas en las palmas de tus manos. Fricciona suavemente.</p>
            <p style="margin-top: 8px;"><strong style="color: var(--s-dark);">3. Ritualiza.</strong> Aplica en sienes, muñecas y pecho. Cierra los ojos y permite que el aroma te acompañe.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- COMPLETA TU RITUAL -->
    <section class="section section--cream" style="margin: 0 calc(-1 * var(--sp-l)); padding-left: var(--sp-l); padding-right: var(--sp-l);">
      <div class="text-center mb-2xl">
        <div class="label mb-s reveal">COMPLETA TU RITUAL</div>
        <h2 class="h1 reveal reveal-delay-1">Combina para una experiencia completa</h2>
      </div>
      
      <div class="grid grid-3" style="max-width: 960px; margin: 0 auto;">
        {% for product in collections.all.products limit: 3 %}
          <div class="product-card reveal">
            <div class="product-card-image">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | image_url: width: 400 }}" 
                     alt="{{ product.title }}"
                     loading="lazy">
              {% else %}
                <div style="width: 100%; aspect-ratio: 1; background: linear-gradient(135deg, #F5F0EB 0%, #D6CFC7 100%); display: flex; align-items: center; justify-content: center;">
                  <span style="font-family: 'Playfair Display', serif; font-size: 1.5rem; color: #4a3f6b; opacity: 0.2;">{{ product.title | slice: 0, 1 }}</span>
                </div>
              {% endif %}
            </div>
            <div class="product-card-category">{{ product.type | default: "RITUAL" }}</div>
            <div class="product-card-name">{{ product.title }}</div>
            <div class="product-card-price">{{ product.price | money }}</div>
          </div>
        {% endfor %}
      </div>
    </section>

    <!-- ACCORDION TABS -->
    <section class="section">
      <div style="max-width: 720px; margin: 0 auto;">
        <div class="accordion-item open">
          <button class="accordion-header" onclick="toggleAccordion(this)">
            <span>INGREDIENTES</span>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-content" style="max-height: 500px;">
            <div class="accordion-content-inner">
              <p>Cada ingrediente en {{ product.title }} ha sido cuidadosamente seleccionado por su pureza y eficacia.</p>
              <p style="margin-top: 12px;">Nuestros aceites son extraídos de plantas cultivadas en su hábitat natural, sin procesos químicos ni diluciones innecesarias.</p>
              <p style="margin-top: 12px;"><strong style="color: var(--s-dark);">Ingredientes clave:</strong></p>
              <ul style="margin-top: 8px; padding-left: 20px;">
                <li>Eucalipto globulus — Aceite esencial puro</li>
                <li>Origen: Andes peruanos</li>
                <li>Proceso: Destilación al vapor</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" onclick="toggleAccordion(this)">
            <span>ENVÍO Y DEVOLUCIONES</span>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              <p><strong style="color: var(--s-dark);">Envío gratuito</strong> en pedidos superiores a S/. 200.</p>
              <p style="margin-top: 8px;">Envío estándar: 3-5 días hábiles.</p>
              <p>Envío express: 1-2 días hábiles.</p>
              <p style="margin-top: 12px;"><strong style="color: var(--s-dark);">Devoluciones:</strong> Aceptamos devoluciones dentro de los 30 días posteriores a la compra. El producto debe estar sin abrir y en su empaque original.</p>
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" onclick="toggleAccordion(this)">
            <span>PREGUNTAS FRECUENTES</span>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              <p><strong style="color: var(--s-dark);">¿Los aceites son aptos para todo tipo de piel?</strong></p>
              <p>Sí, nuestros aceites esenciales son puros y naturales, adecuados para todo tipo de piel. Sin embargo, te recomendamos hacer una prueba de sensibilidad antes de usar.</p>
              
              <p style="margin-top: 16px;"><strong style="color: var(--s-dark);">¿Cómo debo almacenar los aceites?</strong></p>
              <p>Consérvalos en un lugar fresco y seco, alejados de la luz directa. Esto preserva sus propiedades terapéuticas por más tiempo.</p>

              <p style="margin-top: 16px;"><strong style="color: var(--s-dark);">¿Puedo usar los aceites durante el embarazo?</strong></p>
              <p>Te recomendamos consultar con tu médico antes de usar aceites esenciales durante el embarazo o lactancia.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- COMPRA SEGURA -->
    <section class="section section--cream" style="text-align: center;">
      <div class="label mb-l reveal">COMPRA CON CONFIANZA</div>
      <div class="grid grid-4 reveal reveal-delay-1">
        <div class="benefit-item">
          <div class="benefit-icon">🔒</div>
          <div class="benefit-text">Pago seguro</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">📦</div>
          <div class="benefit-text">Envío protegido</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">↩️</div>
          <div class="benefit-text">Devolución 30 días</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">💬</div>
          <div class="benefit-text">Soporte 24/7</div>
        </div>
      </div>
    </section>
  </div>
</div>

<script>
function toggleAccordion(button) {
  const item = button.closest('.accordion-item');
  const isOpen = item.classList.contains('open');
  
  // Close all
  document.querySelectorAll('.accordion-item').forEach(el => el.classList.remove('open'));
  
  // Toggle current
  if (!isOpen) {
    item.classList.add('open');
  }
}

// Quantity selector
document.querySelectorAll('.quantity-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const action = btn.dataset.action;
    const qtyEl = document.getElementById('quantity');
    let qty = parseInt(qtyEl.textContent);
    
    if (action === 'increase') qty++;
    if (action === 'decrease' && qty > 1) qty--;
    
    qtyEl.textContent = qty;
  });
});

// Variant selection
document.querySelectorAll('.variant-option').forEach(btn => {
  btn.addEventListener('click', () => {
    const option = btn.dataset.option;
    document.querySelectorAll(`.variant-option[data-option="${option}"]`).forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });
});

// Add to cart
document.getElementById('add-to-cart').addEventListener('click', () => {
  // Shopify AJAX API
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      items: [{
        id: {{ product.selected_or_first_available_variant.id }},
        quantity: parseInt(document.getElementById('quantity').textContent)
      }]
    })
  })
  .then(res => res.json())
  .then(data => {
    // Open cart drawer
    document.querySelector('.cart-overlay').classList.add('active');
    document.querySelector('.cart-drawer').classList.add('active');
  })
  .catch(err => console.error('Error:', err));
});
</script>

{% schema %}
{
  "name": "Serenne Product",
  "settings": [],
  "blocks": []
}
{% endschema %}
