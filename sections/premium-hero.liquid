<section class="hero" id="hero-{{ section.id }}">
  <div class="hero-image-wrap">
    {% if section.settings.hero_image != blank %}
      <img 
        src="{{ section.settings.hero_image | image_url: width: 1200 }}" 
        alt="{{ section.settings.hero_image.alt | default: 'Serenne' }}"
        loading="eager"
        width="1200"
        height="1600"
      >
    {% else %}
      <img 
        src="https://cdn.shopify.com/s/files/1/0998/6283/9609/files/hero-lifestyle_jpg.jpg?v=1780878588" 
        alt="Serenne — Skincare Premium"
        loading="eager"
        width="1200"
        height="1600"
      >
    {% endif %}
  </div>
  
  <div class="hero-content">
    {%- comment -%} Force Spanish {%- endcomment -%}
    {% assign hero_badge = 'Nueva Colección 2026' %}
    {% assign hero_title = 'Tu piel merece <em>rituales intencionales</em>' %}
    {% assign hero_subtitle = 'Formulaciones botánicas de laboratorio. Ingredientes puros que transforman tu piel y elevan tu bienestar diario.' %}
    {% assign hero_button_text = 'Explorar Colección' %}
    {% assign hero_button_link = '/collections' %}
    {% assign hero_button_text_2 = 'Nuestra Filosofía' %}
    {% assign hero_button_link_2 = '/pages/about' %}

    <div class="hero-badge reveal">
      <span>{{ hero_badge }}</span>
    </div>

    <h1 class="hero-title reveal">
      {{ hero_title }}
    </h1>

    <p class="hero-subtitle reveal">
      {{ hero_subtitle }}
    </p>

    <div class="hero-cta reveal">
      <a href="{{ hero_button_link }}" class="btn btn--filled">
        {{ hero_button_text }}
      </a>
      <a href="{{ hero_button_link_2 }}" class="btn">
        {{ hero_button_text_2 }}
      </a>
    </div>
  </div>
  
  <div class="hero-scroll">
    <span>Descubre</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1">
      <rect x="1" y="1" width="14" height="22" rx="7" />
      <line x1="8" y1="6" x2="8" y2="10" />
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero Premium",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Badge Text",
      "default": "Nueva Colección 2026"
    },
    {
      "type": "textarea",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Tu piel merece <em>rituales intencionales</em>"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Formulaciones botánicas de laboratorio. Ingredientes puros que transforman tu piel y elevan tu bienestar diario."
    },
    {
      "type": "text",
      "id": "hero_button_text",
      "label": "Primary Button Text",
      "default": "Explorar Colección"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "hero_button_text_2",
      "label": "Secondary Button Text",
      "default": "Nuestra Filosofía"
    },
    {
      "type": "url",
      "id": "hero_button_link_2",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Premium"
    }
  ]
}
{% endschema %}
