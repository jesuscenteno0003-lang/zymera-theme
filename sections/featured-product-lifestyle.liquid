<section class="zym-lifestyle-section" style="padding:7rem 0;background:#FAF9F7;">
  <div class="zym-container">
    <div class="zym-lifestyle-grid">
      <div class="zym-lifestyle-content">
        <span class="zym-section-subtitle" style="text-align:left;">{{ section.settings.subtitle }}</span>
        <h2 class="zym-lifestyle-title">{{ section.settings.title }}</h2>
        <p class="zym-lifestyle-desc">{{ section.settings.description }}</p>
        <ul class="zym-lifestyle-features">
          {% if section.settings.feature_1 != blank %}
            <li><i class="fas fa-check-circle"></i> {{ section.settings.feature_1 }}</li>
          {% endif %}
          {% if section.settings.feature_2 != blank %}
            <li><i class="fas fa-check-circle"></i> {{ section.settings.feature_2 }}</li>
          {% endif %}
          {% if section.settings.feature_3 != blank %}
            <li><i class="fas fa-check-circle"></i> {{ section.settings.feature_3 }}</li>
          {% endif %}
        </ul>
        {% if section.settings.btn_text != blank %}
          <a href="{{ section.settings.btn_link }}" class="zym-btn zym-btn--primary">{{ section.settings.btn_text }}</a>
        {% endif %}
      </div>
      <div class="zym-lifestyle-images">
        <div class="zym-lifestyle-img-main">
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | image_url: width: 600 }}" alt="{{ section.settings.title }}" loading="lazy">
          {% else %}
            <img src="https://images.unsplash.com/photo-1602928321679-560bb453f190?w=600&q=85" alt="Aceite esencial premium" loading="lazy">
          {% endif %}
        </div>
        <div class="zym-lifestyle-img-accent">
          {% if section.settings.image_2 != blank %}
            <img src="{{ section.settings.image_2 | image_url: width: 300 }}" alt="" loading="lazy">
          {% else %}
            <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=300&q=85" alt="Meditacion" loading="lazy">
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product Lifestyle",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Producto Estrella" },
    { "type": "text", "id": "title", "label": "Title", "default": "Aceite Esencial de Lavanda — Grado Terapeutico" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Extraido de lavanda francesa de altitud, destilado en frio para preservar sus propiedades calmantes. Un基本 esencial para tu ritual nocturno." },
    { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "100% Puro — Sin diluciones ni aditivos" },
    { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "Destilado en frio, lote a lote" },
    { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Envase de vidrio reciclado con dosificador" },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Descubrir Ahora" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "image_picker", "id": "image", "label": "Main Image" },
    { "type": "image_picker", "id": "image_2", "label": "Accent Image" }
  ],
  "presets": [ { "name": "Featured Product Lifestyle" } ]
}
{% endschema %}
