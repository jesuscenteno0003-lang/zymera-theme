<section class="zym-collection-page zym-container">
  <div class="zym-section-header" style="padding-top: 100px;">
    <h1 class="zym-title">{{ collection.title | default: "Tienda" }}</h1>
    {% if collection.description != blank %}
      <p class="zym-desc">{{ collection.description }}</p>
    {% endif %}
  </div>

  <div class="zym-products-grid">
    {% for product in collection.products %}
      {% render 'product-card', product: product %}
    {% else %}
      <p style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--zym-gray-500);">No hay productos en esta coleccion.</p>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Template",
  "settings": []
}
{% endschema %}
